# ─────────────────────────────────────────────────────
# CodeDost Backend — Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values
# 3. NEVER commit .env to GitHub — it is in .gitignore
# ─────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Free cluster: mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/codedost?retryWrites=true&w=majority

# JWT Secrets — generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_string
JWT_REFRESH_SECRET=replace_with_different_64_char_random_string

# Token expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
PORT=5000
NODE_ENV=production

# Your frontend URL — no trailing slash
FRONTEND_URL=https://code-dost.vercel.app

# Cookie signing secret
COOKIE_SECRET=replace_with_another_random_string

# Usage limits per tier (can override without code changes)
ANONYMOUS_MONTHLY_LIMIT=5
ANONYMOUS_MAX_LINES=300
FREE_MONTHLY_LIMIT=20
FREE_MAX_LINES=1000
PRO_MONTHLY_LIMIT=999999
PRO_MAX_LINES=999999
