MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/codedost?appName=Cluster0

JWT_SECRET=<generate-a-64-char-hex-secret>

JWT_REFRESH_SECRET=<generate-a-64-char-hex-secret>

JWT_ACCESS_EXPIRY=15m

JWT_REFRESH_EXPIRY=7d

PORT=5000

NODE_ENV=development

FRONTEND_URL=https://your-frontend-domain.vercel.app

ALLOWED_ORIGIN=https://your-frontend-domain.vercel.app

COOKIE_SECRET=<generate-a-64-char-hex-secret>

GUMROAD_PRODUCT_PERMALINK=your-gumroad-product-slug

ANONYMOUS_MONTHLY_LIMIT=5

ANONYMOUS_MAX_LINES=300

FREE_MONTHLY_LIMIT=20

FREE_MAX_LINES=1000

PRO_MONTHLY_LIMIT=999999

PRO_MAX_LINES=999999